	// ADD SLIDEDOWN ANIMATION TO DROPDOWN //
    $('.toplinks').on('show.bs.dropdown', function (e) {
		var ddMenu = $(e.relatedTarget).next();
        $(ddMenu).stop(true, true).slideDown();
        $(ddMenu).find("a").addClass("animated");
        window.scrollBy(0, 1);
    });

    // ADD SLIDEUP ANIMATION TO DROPDOWN //
	$('.toplinks').on('hide.bs.dropdown', function (e) {
		var ddMenu = $(e.relatedTarget).next();
        ddMenu.slideUp();
    });

    $(".toplinks .toplinks__ul > li > a").each(function (index, value) {
        $(this).attr("data-wow-delay", index / 10 + "s");
        $(this).addClass("wow fadeIn");
    });

    $(".toplinks .dropdown-menu").each(function (index, value) {
		$(this).find("a").each(function (index, value) {
			$(this).attr("data-wow-delay", index / 10 + "s");
			$(this).addClass("wow fadeIn");
		});
    });

    // Prevent dropdown from closing when clicking inside it
    $('.toplinks__dropdown').on('click', function (e) {
        e.stopPropagation();
    });
	
